# Provedor de LLM: mock | openai | bedrock
# mock  -> roda offline (sumarização extrativa), custo zero — ideal para demo
# openai -> requer OPENAI_API_KEY
# bedrock -> requer credenciais AWS configuradas (aws configure)
LLM_PROVIDER=mock

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# AWS Bedrock
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0
